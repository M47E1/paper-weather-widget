<Grid
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="386"
    Height="448">
    <Border
        CornerRadius="14"
        Padding="12"
        Background="#FFFAF9F5"
        BorderThickness="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel x:Name="DragHandle">
                    <TextBlock Text="Weather" FontSize="17" FontWeight="SemiBold" Foreground="#2F2C25" />
                    <TextBlock Text="Loading" FontSize="11" Foreground="#8A867A" />
                </StackPanel>
                <Button Grid.Column="1" Width="30" Height="30" Content="R" x:Name="ManualRefreshButton" />
                <Button Grid.Column="2" Width="30" Height="30" Content="S" x:Name="SettingsToggleButton" />
                <Button Grid.Column="3" Width="30" Height="30" Content="x" />
            </Grid>
            <Border Grid.Row="1" Margin="0,12,0,8" Height="34" CornerRadius="10" Background="#FFF3F1EA" />
            <Border Grid.Row="2" CornerRadius="12" Padding="14" Background="#FFFFFFFF">
                <TextBlock Text="Fetching weather" Foreground="#8A867A" />
            </Border>
            <UniformGrid Grid.Row="3" Columns="2" />
            <Border Grid.Row="4" x:Name="SettingsPanel" Visibility="Collapsed" CornerRadius="12" Padding="10" Background="#FFFFFFFF">
                <StackPanel>
                    <ComboBox x:Name="ProvinceCombo" />
                    <ComboBox x:Name="CityCombo" />
                    <ComboBox x:Name="DistrictCombo" />
                    <ComboBox x:Name="RefreshIntervalCombo" />
                    <ComboBox x:Name="ForecastSlotCombo" />
                    <StackPanel Orientation="Horizontal" x:Name="LanguageControl" />
                </StackPanel>
            </Border>
            <TextBlock Grid.Row="6" Margin="0,10,0,0" Text="Updating..." FontSize="11" Foreground="#8A867A" />
        </Grid>
    </Border>
</Grid>
